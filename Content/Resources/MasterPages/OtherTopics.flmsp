        <script type="text/javascript">/*<![CDATA[*/function sendForm() {
	var url = document.URL;
	var hash = window.location.hash;
	var len = hash.length - 1;
	hash = hash.substr(hash.length - len);
	//var n = url.search("#");
	//url = url.substr(0,n);
	if(url.length < 1)
		{
			url = "NoURL";
		}
	if(hash.length < 1)
		{
			hash = "NoTopic";
		}
			window.open("https://support.bplogix.net/form.aspx?pid=81f1c689-ddcd-49ca-b9fa-6a096a78f075&formid=aefcc679-e478-47a0-b6ce-16a0df016e22&topic=" + hash + "&url=" + url,"Help Doc Feedback", "height=500,width=700,status=no,toolbar=no,menubar=no,location=no,scrollbars=no");
	}
