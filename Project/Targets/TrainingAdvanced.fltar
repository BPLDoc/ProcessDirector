<?xml version="1.0" encoding="utf-8"?>
<CatapultTarget
  Version="2"
  Comment="New Target"
  Type="PDF"
  Destinations=""
  MasterToc="/Project/TOCs/Advanced Training.fltoc"
  TargetLanguage="en-us"
  MasterPageLayout="/Content/Resources/MasterPages/PrintLayout.flpgl"
  ConditionTagExpression="include[&quot;General.Advanced Training&quot;] exclude[&quot;General.All Hidden&quot; or &quot;General.Core Training&quot; or &quot;General.Not Printed&quot; or &quot;General.SysAdmin Training&quot;] "
  InjectEmptyPages="true"
  PatchHeadingLevels="false"
  MasterStylesheet="/Content/Resources/Stylesheets/TrainingHandbook.css"
  GlossaryTermConversion="marked"
  conditions="General.Advanced Training">
  <PrintedOutput
    CollapseMargins="false"
    GenerateTOCProxy="true"
    GenerateIndexProxy="false"
    GenerateGlossaryProxy="false"
    ExpandingTextConversion="expand" />
  <DocumentProperties
    Title="Advanced Training"
    Author="BP Logix Inc."
    Subject="Advanced Training Handbook" />
  <PDF
    ShowUsedBookmarks="false"
    InitialMagnification="Fit"
    PageMode="UseNone" />
  <Destinations>
    <Destination
      Link="/Project/Destinations/Production.fldes" />
  </Destinations>
  <Glossaries />
  <Variables>
    <Variable
      Name="Print/DocTitle">Advanced Proficiency Training Handbook</Variable>
  </Variables>
</CatapultTarget>