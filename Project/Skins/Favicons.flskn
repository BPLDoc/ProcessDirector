<?xml version="1.0" encoding="utf-8"?>
<CatapultSkin
  Version="4"
  SkinType="Component"
  Comment="HTML5 Favicon skin"
  ComponentType="Favicon">
  <Stylesheet>
    <Resources>
      <Resource
        Name="favicon.png"></Resource>
      <Resource
        Name="faviconw.png"></Resource>
    </Resources>
  </Stylesheet>
  <Master
    Image="favicon.png" />
  <Browser>
    <SmallFavicon
      Image="(generated)"
      SizePx="16 px" />
    <MediumFavicon
      Image="(generated)"
      SizePx="32 px" />
    <LargeFavicon
      Image="(generated)"
      SizePx="96 px" />
  </Browser>
  <ShortcutIcon
    Image="(generated)" />
  <Touch>
    <TouchIcon
      Image="(generated)"
      SizePx="180 px" />
  </Touch>
  <Windows
    TileColor="#D0DFED"
    WebURL="https://doc.bplogix.com/">
    <MicrosoftSmallTile
      Image="(generated)" />
    <MicrosoftMediumTile
      Image="(generated)" />
    <MicrosoftWideTile
      Image="faviconw.png" />
    <MicrosoftLargeTile
      Image="(generated)" />
  </Windows>
  <Strings />
</CatapultSkin>