<?xml version="1.0" encoding="utf-8"?>
<CatapultSkin
  Version="3"
  SkinType="WebHelp2"
  ComponentType="MasterPage"
  TemplateName="Fluid"
  Comment="HTML5 Fluid Layout"
  EnableResponsiveOutput="true"
  RemoveImagesOnSave="true"
  CommentsInTopic="false"
  DisplayCommunitySearchResults="false">
  <Stylesheet>
    <Resources>
      <Resource
        Name="BP_Logo.png"></Resource>
    </Resources>
    <Styles>
      <Medium
        Name="Tablet">
        <Style
          Name="Navigation Slide Out Button">
          <Properties></Properties>
        </Style>
        <Style
          Name="Navigation Panel">
          <Properties></Properties>
        </Style>
        <Style
          Name="Navigation Panel Item">
          <Properties>
            <Property
              Name="LineHeight">1</Property>
          </Properties>
        </Style>
        <Style
          Name="Search Filter">
          <Properties></Properties>
        </Style>
        <Style
          Name="Search Filter Drop-down">
          <Properties></Properties>
        </Style>
        <Style
          Name="Search Filter Drop-down (hover)">
          <Properties></Properties>
        </Style>
      </Medium>
      <Style
        Name="Header">
        <Properties>
          <Property
            Name="Height">122px</Property>
          <Property
            Name="PaddingTop">0px</Property>
          <Property
            Name="PaddingBottom">1px</Property>
          <Property
            Name="BackgroundColor">#5284af</Property>
        </Properties>
      </Style>
      <Style
        Name="Menu Item">
        <Classes>
          <StyleClass
            Name="2nd Level">
            <Properties>
              <Property
                Name="PaddingRight">10px</Property>
              <Property
                Name="MarginRight">0px</Property>
            </Properties>
          </StyleClass>
          <StyleClass
            Name="3rd Level">
            <Properties>
              <Property
                Name="PaddingRight">10px</Property>
            </Properties>
          </StyleClass>
          <StyleClass
            Name="4th Level">
            <Properties>
              <Property
                Name="PaddingRight">10px</Property>
            </Properties>
          </StyleClass>
        </Classes>
        <Properties></Properties>
      </Style>
      <Style
        Name="Search Input">
        <Properties>
          <Property
            Name="BackgroundColor">#ffffff</Property>
          <Property
            Name="FontFamily">"Myriad Pro", Arial, sans-serif</Property>
        </Properties>
      </Style>
      <Style
        Name="Menu">
        <Properties>
          <Property
            Name="Float">right</Property>
          <Property
            Name="BackgroundColor">transparent</Property>
          <Property
            Name="AlignmentHorizontal">right</Property>
          <Property
            Name="FontFamily">Nunito Sans</Property>
        </Properties>
        <Classes>
          <StyleClass
            Name="1st Level">
            <Properties>
              <Property
                Name="BackgroundColor">#5f6a6d</Property>
            </Properties>
          </StyleClass>
        </Classes>
      </Style>
      <Style
        Name="Logo">
        <Properties>
          <Property
            Name="BackgroundImage">url('BP_Logo.png')</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Bar">
        <Properties>
          <Property
            Name="MarginTop">0px</Property>
          <Property
            Name="BorderTopLeftRadius">4px</Property>
          <Property
            Name="BorderTopRightRadius">4px</Property>
          <Property
            Name="BorderBottomRightRadius">4px</Property>
          <Property
            Name="BorderBottomLeftRadius">4px</Property>
          <Property
            Name="MarginBottom">6px</Property>
          <Property
            Name="Height">1.7em</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Submit Button">
        <Properties>
          <Property
            Name="BackgroundColor">#ffffff</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Heading">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
          <Property
            Name="Color">#5284af</Property>
          <Property
            Name="LineHeight">1.6em</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Result Abstract">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
          <Property
            Name="FontSize">0.9em</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Result Link">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
          <Property
            Name="Color">#5284af</Property>
          <Property
            Name="FontWeight">bold</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Filter Drop-down">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Result Path">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
          <Property
            Name="FontWeight">bold</Property>
          <Property
            Name="Color">#5f6a6d</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Glossary Result">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Glossary Definition">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Glossary Term">
        <Properties>
          <Property
            Name="Color">#393f45</Property>
          <Property
            Name="FontFamily">Nunito Sans</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Pagination Item">
        <Properties>
          <Property
            Name="FontFamily">Nunito Sans</Property>
          <Property
            Name="Color">#5f6a6d</Property>
          <Property
            Name="FontWeight">bold</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Pagination Item (hover)">
        <Properties>
          <Property
            Name="Color">#808080</Property>
        </Properties>
      </Style>
      <Style
        Name="Search Pagination Item (selected)">
        <Properties>
          <Property
            Name="Color">#5284af</Property>
        </Properties>
      </Style>
      <Style
        Name="Menu Item (hover)">
        <Classes>
          <StyleClass
            Name="1st Level">
            <Properties>
              <Property
                Name="BackgroundColor">#5284af</Property>
            </Properties>
          </StyleClass>
        </Classes>
      </Style>
      <Style
        Name="Search Results">
        <Properties>
          <Property
            Name="LineHeight">1.3em</Property>
        </Properties>
      </Style>
    </Styles>
    <Stylesheet></Stylesheet>
  </Stylesheet>
  <WebHelpOptions
    NavigationPanePosition="Right"
    TopMenuDepth="2" />
  <Strings>
    <Stylesheet
      lang="en-us">
      <Stylesheet>
        <Resources />
        <Styles>
          <Medium
            Name="Tablet">
            <Style
              Name="Navigation Slide Out Button">
              <Properties />
            </Style>
            <Style
              Name="Navigation Panel">
              <Properties />
            </Style>
            <Style
              Name="Navigation Panel Item">
              <Properties>
                <Property
                  Name="LineHeight">1</Property>
              </Properties>
            </Style>
            <Style
              Name="Search Filter">
              <Properties />
            </Style>
            <Style
              Name="Search Filter Drop-down">
              <Properties />
            </Style>
            <Style
              Name="Search Filter Drop-down (hover)">
              <Properties />
            </Style>
          </Medium>
          <Style
            Name="Header">
            <Properties>
              <Property
                Name="Height">122px</Property>
              <Property
                Name="BackgroundColor">#292928</Property>
            </Properties>
          </Style>
          <Style
            Name="Menu Item">
            <Classes>
              <StyleClass
                Name="2nd Level">
                <Properties>
                  <Property
                    Name="PaddingRight">10px</Property>
                  <Property
                    Name="MarginRight">0px</Property>
                </Properties>
              </StyleClass>
              <StyleClass
                Name="3rd Level">
                <Properties>
                  <Property
                    Name="PaddingRight">10px</Property>
                </Properties>
              </StyleClass>
              <StyleClass
                Name="4th Level">
                <Properties>
                  <Property
                    Name="PaddingRight">10px</Property>
                </Properties>
              </StyleClass>
            </Classes>
            <Properties />
          </Style>
          <Style
            Name="Search Input">
            <Properties>
              <Property
                Name="BackgroundColor">#ffffff</Property>
            </Properties>
          </Style>
          <Style
            Name="Menu">
            <Properties>
              <Property
                Name="Float">right</Property>
            </Properties>
          </Style>
          <Style
            Name="Search Heading">
            <Properties>
              <Property
                Name="Format">Your search for {query} returned {total_results} result(s). Try enclosing your search term in quotes for more than one word, or using the Filter icon in the search bar to filter your results.</Property>
            </Properties>
          </Style>
        </Styles>
        <Stylesheet />
      </Stylesheet>
    </Stylesheet>
  </Strings>
</CatapultSkin>